{
	"name": "tangl-viewer",
	"version": "0.0.1",
	"scripts": {
		"build:vite:win": "set LIB_NAME=es && vite build && set LIB_NAME=cjs && vite build",
		"build:vite": "export LIB_NAME=es && vite build && export LIB_NAME=cjs && vite build",
		"build:docs": "typedoc",
		"build:docs-global": "typedoc --out ../../../docs/docs/api/tangl-viewer",
		"start:es": "set LIB_NAME=es && vite build --watch",
		"start:cjs": "set LIB_NAME=cjs && vite build --watch"
	},
	"files": [
		"dist"
	],
	"module": "dist/index.es.mjs",
	"main": "dist/index.es.mjs",
	"types": "dist/index.d.ts",
	"typings": "dist/index.d.ts",
	"typesVersions": {
		"*": {
			"cjs": [
				"dist/index.cjs.d.ts"
			]
		}
	},
	"exports": {
		".": {
			"import": "./dist/index.es.mjs",
			"require": "./dist/index.es.mjs"
		},
		"./cjs": {
			"import": "./dist/index.cjs.js",
			"require": "./dist/index.cjs.js"
		}
	},
	"devDependencies": {
		"@types/lodash": "^4.14.185",
		"@types/node": "^18.0.1",
		"@types/three": "^0.142.0",
		"axios": "^0.27.2",
		"fast-triangle-triangle-intersection": "^1.0.7",
		"lodash": "^4.17.21",
		"pug": "^3.0.2",
		"sass": "^1.53.0",
		"three": "^0.142.0",
		"three-mesh-bvh": "^0.5.15",
		"ts-node": "^10.8.2",
		"typedoc": "^0.23.10",
		"typedoc-plugin-markdown": "^3.13.4",
		"typedoc-plugin-merge-modules": "^4.0.1",
		"typedoc-plugin-missing-exports": "^1.0.0",
		"typescript": "^4.7.4",
		"vite": "^3.2.2",
		"vite-plugin-dts": "^1.2.1",
		"vuex": "^4.0.2"
	}
}
